# Streamlit Secrets — API keys for the chat assistant.
#
# LOCAL DEV:  Copy this file to .streamlit/secrets.toml and fill in your keys.
# STREAMLIT CLOUD:  Paste these into App settings → Secrets (TOML format).
#
# At least ONE key (GOOGLE or GROQ) is needed for the free-tier chat to work.
# DO NOT commit secrets.toml to version control.

# Google Gemini API key (default provider — free tier)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY = "your_google_api_key_here"

# Groq API key (alternative free provider)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY = "your_groq_api_key_here"

# Optional: OpenAI API key (for users who prefer OpenAI)
# OPENAI_API_KEY = "sk-your_openai_api_key_here"
